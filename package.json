{
  "name": "mercapi",
  "version": "0.1.0",
  "description": "Node.js client for Mercari Japan API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mercari",
    "api",
    "japan",
    "marketplace",
    "shopping"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhu-kai/mercapi-node"
  },
  "homepage": "https://github.com/zhu-kai/mercapi-node#readme",
  "bugs": {
    "url": "https://github.com/zhu-kai/mercapi-node/issues"
  },
  "author": "Kai Zhu",
  "dependencies": {
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
